# Relay Server
RELAY_HOST=0.0.0.0
RELAY_PORT=8025
RELAY_USERNAME=relay
RELAY_PASSWORD=change_me

# TLS (optional)
TLS_ENABLED=false
TLS_CERT=/certs/cert.pem
TLS_KEY=/certs/key.pem

# SimpleLogin
SL_API_URL=https://app.simplelogin.io
SL_API_KEY=your_api_key

# Upstream SMTP
UPSTREAM_HOST=smtp.gmail.com
UPSTREAM_PORT=587
UPSTREAM_USERNAME=your@gmail.com
UPSTREAM_PASSWORD=your_app_password
UPSTREAM_STARTTLS=true
UPSTREAM_TIMEOUT=15

# Logging
LOG_LEVEL=INFO